{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "runtime-windows",
  "description": "Recording-flow overlay windows (selector + recorder) and main-window events.",
  "windows": ["main", "selector", "recorder"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus"
  ]
}
