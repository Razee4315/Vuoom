{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vuoom",
  "version": "0.1.31",
  "identifier": "dev.vuoom.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vuoom",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "maximized": true,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Razee4315/Vuoom/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQyOTkzNDg1OEMzMzU3RTAKUldUZ1Z6T01oVFNaMGdwMGdxMjFvclJLK2p4K1dBcmZLeWZXVE1wZmdjVVRiWnUyS2Y0RS9lY24K"
    }
  }
}
